{
  "name": "education-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch scripts/dev.ts",
    "dev:spa": "vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "validate": "bun scripts/validate.ts",
    "start": "bun server/index.ts",
    "build:app": "bun run build && bun scripts/embed-dist.ts && bun build --compile server/index.ts --outfile education-app"
  },
  "dependencies": {
    "@vue-flow/background": "=1.3.2",
    "@vue-flow/controls": "=1.1.3",
    "@vue-flow/core": "=1.48.2",
    "@vueuse/core": "=14.2.1",
    "echarts": "=6.0.0",
    "highlight.js": "=11.11.1",
    "js-yaml": "=4.1.1",
    "lucide-vue-next": "=1.0.0",
    "markdown-it": "=14.1.1",
    "naive-ui": "=2.44.1",
    "pinia": "=2.3.1",
    "vue": "=3.5.32",
    "vue-echarts": "=8.0.1",
    "vue-router": "=4.3.0"
  },
  "devDependencies": {
    "@types/bun": "=1.3.12",
    "@types/js-yaml": "=4.0.9",
    "@types/markdown-it": "=14.1.2",
    "@vitejs/plugin-vue": "=6.0.6",
    "typescript": "=5.9.3",
    "vite": "=8.0.8",
    "vue-tsc": "=3.2.4"
  }
}
